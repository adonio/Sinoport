{
  "name": "@sinoport/api-worker",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --port 8787",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply sinoport-api-local --local",
    "db:migrate:remote": "wrangler d1 migrations apply sinoport-api-local --remote",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@sinoport/auth": "file:../../packages/auth",
    "@sinoport/contracts": "file:../../packages/contracts",
    "@sinoport/domain": "file:../../packages/domain",
    "@sinoport/repositories": "file:../../packages/repositories",
    "hono": "^4.7.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250410.0",
    "typescript": "^5.8.3",
    "wrangler": "^4.13.2"
  }
}
